---
import { getCollection } from 'astro:content';
import type { GPU } from '../../data/gpus';
import type { LLMModel } from '../../data/models';
import { getModelsForVram } from '../../data/models';
import Base from '../../layouts/Base.astro';
import ModelCard from '../../components/ModelCard.astro';
import { affiliates } from '../../data/affiliates';

export async function getStaticPaths() {
  const gpuEntries = await getCollection('gpus');
  return gpuEntries.map((entry) => ({
    params: { gpu: entry.data.slug },
    props: { gpu: entry.data as GPU },
  }));
}

const { gpu } = Astro.props as { gpu: GPU };
const modelEntries = await getCollection('models');
const models: LLMModel[] = modelEntries.map(({ data }) => data as LLMModel);
const matches = getModelsForVram(models, gpu.vram);
const title = `Best LLMs for ${gpu.name} (${gpu.vram}GB VRAM) — 2026`;
const description = `Top ${matches.length} open-source AI models you can run locally on ${gpu.name}. Includes ollama commands, VRAM requirements, and setup guides.`;
---
<Base title={title} description={description}>
  <div class="container" style="padding-top:2rem">
    <div class="page-header">
      <a href="/" style="color:var(--text-muted);font-size:.85rem">← Back to Matcher</a>
      <h1>{title}</h1>
      <p class="subtitle">{matches.length} models matched · Share this page with others who have {gpu.name}</p>
      <div style="display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1rem">
        <button class="btn btn-secondary" onclick="navigator.clipboard.writeText(location.href);this.textContent='✅ Copied!';setTimeout(()=>this.textContent='📤 Copy link',1500)">
          📤 Copy link
        </button>
        {gpu.amazonLink && (
          <a
            href={gpu.amazonLink}
            class="btn btn-secondary"
            target="_blank"
            rel="noopener noreferrer sponsored"
            onclick="trackEvent('affiliate_click',{affiliate:'amazon_gpu',context:'match_page'})"
          >
            🛒 Buy {gpu.name} on Amazon
          </a>
        )}
      </div>
    </div>

    <div class="results-grid" style="margin-top:2rem">
      {matches.map((model, index) => (
        <ModelCard
          model={model}
          userVram={gpu.vram}
          rank={index + 1}
          estimatedTps={typeof model.tpsRtx4090 === 'number' && typeof gpu.tpsRatio === 'number'
            ? Math.round(model.tpsRtx4090 * gpu.tpsRatio)
            : undefined}
        />
      ))}
    </div>

    {matches.length === 0 && (
      <div class="card" style="text-align:center;padding:3rem">
        <p>No models fit {gpu.vram}GB VRAM. Consider cloud GPU:</p>
        <a href={affiliates.runpod} class="btn btn-primary" style="margin-top:1rem" target="_blank" rel="noopener noreferrer sponsored">
          Try RunPod Cloud GPU →
        </a>
      </div>
    )}
  </div>
  <style>
    .page-header { margin-bottom: 1rem; }
    .page-header h1 { font-size: clamp(1.3rem,3vw,2rem); margin: .5rem 0; }
    .subtitle { color: var(--text-secondary); }
    .results-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
  </style>
</Base>
