---
import { getCollection } from 'astro:content';
import type { LLMModel } from '../data/models';
import { affiliates } from '../data/affiliates';
import Base from '../layouts/Base.astro';

const modelEntries = await getCollection('models');
const models: LLMModel[] = modelEntries.map(({ data }) => data as LLMModel);
---
<Base title="LLM Leaderboard — Most Popular Local AI Models by GPU"
  description="Community-voted rankings of the most popular local LLMs. Vote for the model you actually use on your GPU.">
  <div class="container" style="padding-top:2rem">
    <h1>🏆 Community Leaderboard</h1>
    <p style="color:var(--text-secondary);margin-bottom:2rem">
      Which LLMs do people actually run locally? Vote after matching your GPU.
    </p>
    <div id="board">
      <div class="loading">Loading votes...</div>
    </div>
    <div style="margin-top:2rem;text-align:center">
      <a href={affiliates.runpod} class="btn btn-secondary" target="_blank" rel="noopener noreferrer sponsored"
         onclick="trackEvent('affiliate_click',{affiliate:'runpod',context:'leaderboard'})">
        ⚡ Run top models in the cloud — RunPod
      </a>
    </div>
  </div>
</Base>

<script id="leaderboard-models" type="application/json" set:html={JSON.stringify(models)}></script>

<script>
import type { LLMModel } from '../data/models';

const modelDataEl = document.getElementById('leaderboard-models');
const models = modelDataEl?.textContent ? JSON.parse(modelDataEl.textContent) as LLMModel[] : [];

async function loadLeaderboard() {
  const board = document.getElementById('board');
  if (!board) return;
  try {
    const response = await fetch('/api/leaderboard');
    const data = await response.json() as Array<{ model_slug: string; votes: number }>;
    if (!data.length) {
      board.innerHTML = '<p style="color:var(--text-secondary);text-align:center">No votes yet. Be the first! <a href="/">Match your GPU →</a></p>';
      return;
    }
    board.innerHTML = `
      <div class="board-head board-row">
        <span class="board-rank">#</span>
        <div class="board-info">Model</div>
        <div class="board-tps">RTX 4090 tok/s</div>
        <div class="board-votes">Votes</div>
      </div>
      ${data.map((row, index) => {
        const model = models.find((entry) => entry.slug === row.model_slug);
        const name = model?.name || row.model_slug;
        const tps = typeof model?.tpsRtx4090 === 'number' ? `~${Math.round(model.tpsRtx4090)} tok/s` : '—';
        return `
          <div class="board-row">
            <span class="board-rank">#${index + 1}</span>
            <div class="board-info">
              <a href="/models/${row.model_slug}" class="board-name">${name}</a>
              ${model ? `<div class="board-tags">${model.tags.map((tag) => `<span class="badge tag">${tag}</span>`).join('')}</div>` : ''}
            </div>
            <div class="board-tps">${tps}</div>
            <div class="board-votes">
              <span class="vote-count">${row.votes}</span>
              <span style="font-size:.75rem;color:var(--text-muted)">votes</span>
            </div>
          </div>`;
      }).join('')}`;
  } catch {
    board.innerHTML = '<p style="color:var(--text-muted)">Could not load leaderboard. Try again later.</p>';
  }
}

loadLeaderboard();
</script>

<style>
  .loading { text-align:center;color:var(--text-muted);padding:2rem; }
  .board-row { display:grid;grid-template-columns:56px minmax(0,1fr) 120px 90px;align-items:center;gap:1rem;padding:.8rem 1rem;border:1px solid var(--border);border-radius:var(--radius);margin-bottom:.5rem;background:var(--bg-card); }
  .board-head { color:var(--text-muted);font-size:.78rem;font-weight:600; }
  .board-rank { font-size:1.1rem;font-weight:700;color:var(--text-muted);min-width:2rem; }
  .board-info { min-width:0; }
  .board-name { font-weight:600;color:var(--text-primary); }
  .board-tags { display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.3rem; }
  .board-tps { color:var(--accent-green);font-size:.82rem;font-weight:600; }
  .badge.tag { color:var(--accent);border-color:rgba(88,166,255,.3); }
  .vote-count { font-size:1.2rem;font-weight:700;color:var(--accent-green); }
  @media (max-width: 700px) {
    .board-row { grid-template-columns:40px minmax(0,1fr); }
    .board-head .board-tps, .board-head .board-votes { display:none; }
    .board-tps, .board-votes { grid-column:2; }
  }
</style>
