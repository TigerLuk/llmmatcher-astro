---
import Base from '../layouts/Base.astro';
import { gpus } from '../data/gpus';
---
<Base title="GPU LLM Comparison — Compare Which Models Run on Each GPU"
  description="Side-by-side comparison of GPUs and which LLMs they can run. Compare up to 4 GPUs.">
  <div class="container" style="padding-top:2rem">
    <h1>GPU Comparison</h1>
    <p style="color:var(--text-secondary);margin-bottom:1.5rem">
      Select up to 4 GPUs to compare which models they can run
    </p>

    <div id="gpu-picker" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem">
      {gpus.map((g) => (
        <button class="pick-btn" data-slug={g.slug} data-vram={g.vram} data-name={g.name}
          onclick="togglePick(this)">
          {g.name} ({g.vram}GB)
        </button>
      ))}
    </div>

    <div id="compare-table-wrap" style="overflow-x:auto"></div>
  </div>
</Base>

<script>
import { gpus } from '../data/gpus';
import { models } from '../data/models';

let selected: string[] = [];

function togglePick(btn: HTMLButtonElement) {
  const slug = btn.dataset.slug!;
  if (selected.includes(slug)) {
    selected = selected.filter((s) => s !== slug);
    btn.classList.remove('active');
  } else {
    if (selected.length >= 4) return;
    selected.push(slug);
    btn.classList.add('active');
  }
  const url = new URL(location.href);
  url.searchParams.set('gpus', selected.join(','));
  history.replaceState(null, '', url);
  renderTable();
}

function renderTable() {
  const wrap: HTMLElement | null = document.getElementById('compare-table-wrap');
  if (!wrap) return;
  if (selected.length === 0) {
    wrap.innerHTML = '';
    return;
  }

  const selGPUs = selected
    .map((s) => gpus.find((g) => g.slug === s))
    .filter((g): g is NonNullable<(typeof gpus)[number]> => !!g);

  let html = '<table class="compare-table"><thead><tr><th>Model</th>';
  selGPUs.forEach((g) => {
    html += `<th><div>${g.name}</div><div class="vram-label">${g.vram}GB VRAM</div>`;
    if (g.amazonLink) html += `<a href="${g.amazonLink}" class="buy-link" target="_blank" rel="noopener sponsored" onclick="trackEvent('affiliate_click',{affiliate:'amazon_gpu',gpu:'${g.slug}'})">Buy on Amazon →</a>`;
    html += '</th>';
  });
  html += '</tr></thead><tbody>';

  models.forEach((m) => {
    html += `<tr><td><a href="/models/${m.slug}">${m.name}</a><br><span class="vram-req">needs ${m.minVram}GB</span></td>`;
    selGPUs.forEach((g) => {
      const fits = m.minVram <= g.vram;
      html += `<td class="${fits ? 'fit' : 'nofit'}">${fits ? '✅' : '✗'}</td>`;
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  wrap.innerHTML = html;
}

const urlGPUs = new URLSearchParams(location.search).get('gpus');
if (urlGPUs) {
  urlGPUs.split(',').forEach((slug) => {
    const btn = document.querySelector<HTMLButtonElement>(`[data-slug="${slug}"]`);
    if (btn) togglePick(btn);
  });
}

(window as Window & typeof globalThis & { togglePick?: typeof togglePick }).togglePick = togglePick;
</script>

<style>
  .pick-btn { padding:.35rem .8rem;border-radius:20px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-secondary);cursor:pointer;font-size:.82rem;transition:all .15s; }
  .pick-btn.active { border-color:var(--accent);color:var(--accent);background:var(--bg-hover); }
  .compare-table { width:100%;border-collapse:collapse;font-size:.85rem; }
  .compare-table th,.compare-table td { padding:.6rem .8rem;border:1px solid var(--border);text-align:center; }
  .compare-table th { background:var(--bg-card);font-size:.82rem; }
  .compare-table td:first-child { text-align:left; }
  .compare-table tr:hover td { background:var(--bg-hover); }
  .fit { color:var(--accent-green); }
  .nofit { color:var(--text-muted); }
  .vram-label { font-size:.72rem;color:var(--text-muted); }
  .vram-req { font-size:.75rem;color:var(--text-muted); }
  .buy-link { display:block;font-size:.72rem;color:var(--accent);margin-top:.3rem; }
</style>
