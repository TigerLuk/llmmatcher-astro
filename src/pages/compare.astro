---
import { getCollection } from 'astro:content';
import type { GPU } from '../data/gpus';
import type { LLMModel } from '../data/models';
import Base from '../layouts/Base.astro';

const gpuEntries = await getCollection('gpus');
const gpus: GPU[] = gpuEntries.map(({ data }) => data as GPU);
const modelEntries = await getCollection('models');
const models: LLMModel[] = modelEntries.map(({ data }) => data as LLMModel);
const MAX_COMPARE_GPUS = 4;
const compareData = { gpus, models, maxCompareGpus: MAX_COMPARE_GPUS };
---
<Base title="GPU LLM Comparison — Compare Which Models Run on Each GPU"
  description={`Side-by-side comparison of GPUs and which LLMs they can run. Compare up to ${MAX_COMPARE_GPUS} GPUs.`}>
  <div class="container" style="padding-top:2rem">
    <h1>GPU Comparison</h1>
    <p style="color:var(--text-secondary);margin-bottom:1.5rem">
      Select up to {MAX_COMPARE_GPUS} GPUs to compare compatibility and estimated tok/s
    </p>

    <div id="gpu-picker" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem">
      {gpus.map((gpu) => (
        <button class="pick-btn" data-slug={gpu.slug} data-vram={gpu.vram} data-name={gpu.name}
          onclick="togglePick(this)">
          {gpu.name} ({gpu.vram}GB)
        </button>
      ))}
    </div>

    <div id="compare-table-wrap" style="overflow-x:auto"></div>
  </div>
</Base>

<script id="compare-data" type="application/json" set:html={JSON.stringify(compareData)}></script>

<script>
import type { GPU } from '../data/gpus';
import type { LLMModel } from '../data/models';

const compareDataEl = document.getElementById('compare-data');
const compareData = compareDataEl?.textContent
  ? JSON.parse(compareDataEl.textContent) as { gpus: GPU[]; models: LLMModel[]; maxCompareGpus: number }
  : { gpus: [], models: [], maxCompareGpus: 4 };

const gpus = compareData.gpus;
const models = compareData.models;
const maxCompareGpus = compareData.maxCompareGpus ?? 4;
let selected: string[] = [];

function togglePick(button: HTMLButtonElement) {
  const slug = button.dataset.slug;
  if (!slug) return;
  if (selected.includes(slug)) {
    selected = selected.filter((entry) => entry !== slug);
    button.classList.remove('active');
  } else {
    if (selected.length >= maxCompareGpus) return;
    selected.push(slug);
    button.classList.add('active');
  }
  const url = new URL(location.href);
  url.searchParams.set('gpus', selected.join(','));
  history.replaceState(null, '', url);
  renderTable();
}

function renderTable() {
  const wrap = document.getElementById('compare-table-wrap');
  if (!wrap) return;
  if (selected.length === 0) {
    wrap.innerHTML = '';
    return;
  }

  const selectedGpus = selected
    .map((slug) => gpus.find((gpu) => gpu.slug === slug))
    .filter((gpu): gpu is GPU => !!gpu);

  let html = '<table class="compare-table"><thead><tr><th>Model</th>';
  selectedGpus.forEach((gpu) => {
    html += `<th><div>${gpu.name}</div><div class="vram-label">${gpu.vram}GB VRAM</div><div class="tps-label">Compatibility + est. tok/s</div>`;
    if (gpu.amazonLink) html += `<a href="${gpu.amazonLink}" class="buy-link" target="_blank" rel="noopener sponsored" onclick="trackEvent('affiliate_click',{affiliate:'amazon_gpu',gpu:'${gpu.slug}'})">Buy on Amazon →</a>`;
    html += '</th>';
  });
  html += '</tr></thead><tbody>';

  models.forEach((model) => {
    html += `<tr><td><a href="/models/${model.slug}">${model.name}</a><br><span class="vram-req">needs ${model.minVram}GB</span></td>`;
    selectedGpus.forEach((gpu) => {
      const fits = model.minVram <= gpu.vram;
      const estimatedTps = typeof model.tpsRtx4090 === 'number' && typeof gpu.tpsRatio === 'number'
        ? Math.round(model.tpsRtx4090 * gpu.tpsRatio)
        : null;
      html += `<td class="${fits ? 'fit' : 'nofit'}"><div>${fits ? '✅' : '✗'}</div>${fits && estimatedTps !== null ? `<div class="tps-row">~${estimatedTps} tok/s</div>` : ''}</td>`;
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  wrap.innerHTML = html;
}

const urlGpus = new URLSearchParams(location.search).get('gpus');
if (urlGpus) {
  urlGpus.split(',').forEach((slug) => {
    const button = document.querySelector<HTMLButtonElement>(`[data-slug="${slug}"]`);
    if (button) togglePick(button);
  });
}

(window as Window & typeof globalThis & { togglePick?: typeof togglePick }).togglePick = togglePick;
</script>

<style>
  .pick-btn { padding:.35rem .8rem;border-radius:20px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-secondary);cursor:pointer;font-size:.82rem;transition:all .15s; }
  .pick-btn.active { border-color:var(--accent);color:var(--accent);background:var(--bg-hover); }
  .compare-table { width:100%;border-collapse:collapse;font-size:.85rem; }
  .compare-table th,.compare-table td { padding:.6rem .8rem;border:1px solid var(--border);text-align:center; }
  .compare-table th { background:var(--bg-card);font-size:.82rem; }
  .compare-table td:first-child { text-align:left; }
  .compare-table tr:hover td { background:var(--bg-hover); }
  .fit { color:var(--accent-green); }
  .nofit { color:var(--text-muted); }
  .vram-label, .tps-label { font-size:.72rem;color:var(--text-muted); }
  .tps-label { margin-top:.2rem; }
  .vram-req { font-size:.75rem;color:var(--text-muted); }
  .buy-link { display:block;font-size:.72rem;color:var(--accent);margin-top:.3rem; }
  .tps-row { font-size:.72rem;color:var(--accent-green);margin-top:.15rem; }
  @media (max-width: 700px) {
    .compare-table { font-size:.78rem; }
    .compare-table th,.compare-table td { padding:.45rem .55rem; }
  }
</style>
