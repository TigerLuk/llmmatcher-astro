---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPages = await getCollection('pages');
const entry = allPages.find(e => e.id === 'privacy' || e.id === 'privacy.md');
if (!entry) throw new Error('Page not found: privacy');
const { Content } = await render(entry);
---
<Base title="Privacy Policy — LLM Matcher"
  description="LLM Matcher privacy policy. How we collect, use, and protect your data.">
  <div class="container prose" style="max-width:780px;padding-top:2rem">
    <Content />
  </div>
</Base>
