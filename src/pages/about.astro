---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPages = await getCollection('pages');
const entry = allPages.find(e => e.id === 'about' || e.id === 'about.md');
if (!entry) throw new Error('Page not found: about');
const { Content } = await render(entry);
---
<Base title="About LLM Matcher — Affiliate Disclosure"
  description="About LLM Matcher and our affiliate partnership disclosure.">
  <div class="container prose" style="max-width:780px;padding-top:2rem">
    <Content />
  </div>
</Base>
